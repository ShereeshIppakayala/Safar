<% layout("/layouts/boilerplate.ejs") %>

<section class="community-hero d-flex align-items-center text-white">
  <div class="hero-overlay"></div>
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <span class="eyebrow text-uppercase">Community Hub</span>
        <h1 class="display-5 fw-bold mb-3">Learn, share, and connect with travel lovers.</h1>
        <p class="lead mb-4">Join a community built for explorers, hosts, and adventurers who want to discover new places together.</p>
        <a href="#benefits" class="btn btn-outline-light btn-lg me-3">See benefits</a>
        <a href="#join" class="btn btn-light btn-lg">Join now</a>
      </div>
    </div>
  </div>
</section>

<section id="benefits" class="community-features py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="eyebrow text-uppercase text-muted">Why join</span>
      <h2 class="display-6 fw-bold mt-2">A welcoming space for every traveler.</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="community-card p-4 rounded-4 shadow-sm h-100">
          <div class="icon-circle bg-primary text-white mb-3"><i class="fa-solid fa-comments"></i></div>
          <h4>Share real tips</h4>
          <p class="text-muted">Connect with fellow travelers and get honest recommendations for the best places to visit.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="community-card p-4 rounded-4 shadow-sm h-100">
          <div class="icon-circle bg-danger text-white mb-3"><i class="fa-solid fa-map-location-dot"></i></div>
          <h4>Discover new spots</h4>
          <p class="text-muted">Explore curated recommendations from locals and experienced guests across every destination.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="community-card p-4 rounded-4 shadow-sm h-100">
          <div class="icon-circle bg-success text-white mb-3"><i class="fa-solid fa-users"></i></div>
          <h4>Grow your network</h4>
          <p class="text-muted">Build meaningful travel connections and stay inspired by stories from our global community.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="community-stats py-5 bg-light">
  <div class="container">
    <div class="row text-center gy-4">
      <div class="col-md-4">
        <h3 class="display-6 fw-bold">5K+</h3>
        <p class="text-muted mb-0">Active members</p>
      </div>
      <div class="col-md-4">
        <h3 class="display-6 fw-bold">120+</h3>
        <p class="text-muted mb-0">Weekly discussions</p>
      </div>
      <div class="col-md-4">
        <h3 class="display-6 fw-bold">4.9/5</h3>
        <p class="text-muted mb-0">Member satisfaction</p>
      </div>
    </div>
  </div>
</section>

<section id="join" class="community-cta py-5">
  <div class="container">
    <div class="row align-items-center gy-4">
      <div class="col-lg-7">
        <h2 class="fw-bold mb-3">Be part of the travel conversation.</h2>
        <p class="text-muted">Whether you want tips for your next trip or want to share your own experiences, this community is built for travelers like you.</p>
      </div>
      <div class="col-lg-5 text-lg-end">
        <a href="/signup" class="btn btn-primary btn-lg">Create an account</a>
      </div>
    </div>
  </div>
</section>

<section class="community-review py-5 bg-white">
  <div class="container">
    <div class="row justify-content-center text-center mb-5">
      <div class="col-lg-8">
        <span class="eyebrow text-uppercase text-muted">Share feedback</span>
        <h2 class="display-6 fw-bold mt-3">Tell us what you love and how we can improve</h2>
      </div>
    </div>
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="review-card p-4 rounded-4 shadow-sm bg-light">
          <form action="/community/review" method="POST">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="reviewName" class="form-label fw-semibold">Name</label>
                <input type="text" class="form-control" id="reviewName" name="name" placeholder="Your name" required>
              </div>
              <div class="col-md-6">
                <label for="reviewRating" class="form-label fw-semibold">Rating</label>
                <select class="form-select" id="reviewRating" name="rating" required>
                  <option value="">Choose a rating</option>
                  <option value="5">5 - Excellent</option>
                  <option value="4">4 - Great</option>
                  <option value="3">3 - Good</option>
                  <option value="2">2 - Fair</option>
                  <option value="1">1 - Needs improvement</option>
                </select>
              </div>
            </div>
            <div class="my-4">
              <label for="reviewMessage" class="form-label fw-semibold">Review</label>
              <textarea class="form-control" id="reviewMessage" name="message" rows="5" placeholder="Share your thoughts about the website" required></textarea>
            </div>
            <div class="text-end">
              <button type="submit" class="btn btn-primary btn-lg">Submit feedback</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
